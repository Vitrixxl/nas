NAS_LOGIN_PASSWORD=change-me-please
NAS_SESSION_TTL_HOURS=12

# Optionnel : chemin ou enregistrer les medias originaux.
# Par defaut, le serveur utilise NAS_DATA_DIR/files.
# En Docker, garde un chemin sous /data ou ajoute un volume adapte.
# NAS_FILES_DIR=/data/files

# Optionnel, utile pour les liens de partage absolus.
# Remplace par l'IP LAN de ta machine pour tester depuis Android.
NAS_PUBLIC_BASE_URL=https://192.168.1.42
